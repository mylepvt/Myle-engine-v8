CRM_API_PORT=4000
CRM_REDIS_URL=redis://127.0.0.1:6379
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/crm_leads?schema=public
# Integration tests (reassign reset + wallet idempotency): set DATABASE_URL then `npm run test` — Vitest runs `src/integration/*.int.test.ts` when this URL is available.
# Production: keep true — sockets require CRM_JWT_SECRET-signed JWT with `sub` = user id
CRM_REQUIRE_SOCKET_AUTH=true
CRM_JWT_SECRET=change-me-in-production
CRM_INTERNAL_SECRET=dev-only-credit-gate
# Scheduler (worker process): lead REASSIGN + CHECK_STALE + RANK_RECALC — default 60s
CRM_SCHEDULER_INTERVAL_MS=60000
# Legacy: alive scan was on its own interval — superseded by CRM_SCHEDULER_INTERVAL_MS when using new worker runtime
CRM_ALIVE_INTERVAL_MS=300000
# QA Lab (/qa in crm-web) + GET /api/v1/qa/bootstrap — never enable in production
# CRM_QA_LAB=true
